{
  "name": "open-carapace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Multi code-agent orchestration layer with channel-friendly streaming UX",
  "packageManager": "bun@1.3.0",
  "scripts": {
    "build": "bun run tsc -p tsconfig.json",
    "typecheck": "bun run tsc -p tsconfig.json --noEmit",
    "test": "bun test ./test",
    "test:e2e": "bun test ./test/e2e",
    "start": "bun run src/cli/server.ts",
    "gateway": "bun run src/cli/gateway.ts",
    "chat": "bun run src/cli/chat.ts",
    "opencarapace": "bun run src/cli/opencarapace.ts"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "bun-types": "^1.3.0",
    "typescript": "^5.8.2"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.14.1",
    "@clack/prompts": "^1.0.1"
  }
}
